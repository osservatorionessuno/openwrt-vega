+// SPDX-License-Identifier: GPL-2.0+
+/*
+ * Milk-V Vega (Fisilink FSL91030M / Nuclei UX608) board glue.
+ *
+ * Freeloader brings up DDR + caches + UART; OpenSBI hands the FDT
+ * in a1; everything else is in the device tree. board_init is empty
+ * but the symbol is required by the linker.
+ */
+
+#include <init.h>
+
+int board_init(void)
+{
+	return 0;
+}
diff --git a/configs/milkv_vega_defconfig b/configs/milkv_vega_defconfig
new file mode 100644
index 0000000000..1a199603e4
--- /dev/null
+++ b/configs/milkv_vega_defconfig
@@ -0,0 +1,20 @@
+CONFIG_RISCV=y
+CONFIG_SYS_MALLOC_LEN=0x800000
+CONFIG_NR_DRAM_BANKS=1
+CONFIG_HAS_CUSTOM_SYS_INIT_SP_ADDR=y
+CONFIG_CUSTOM_SYS_INIT_SP_ADDR=0x41600000
+CONFIG_DEFAULT_DEVICE_TREE="milkv-vega"
+CONFIG_SYS_LOAD_ADDR=0x42000000
+CONFIG_TARGET_MILKV_VEGA=y
+CONFIG_ARCH_RV64I=y
+CONFIG_RISCV_SMODE=y
+# CONFIG_EFI_LOADER is not set
+CONFIG_AUTOBOOT_KEYED=y
+CONFIG_AUTOBOOT_PROMPT="Press 'asd' to abort autoboot in %d seconds\n"
+CONFIG_AUTOBOOT_STOP_STR="asd"
+CONFIG_USE_BOOTCOMMAND=y
+CONFIG_BOOTCOMMAND="mtd list && mtd read kernel_nand 0x42000000 0 0x600000 && bootm 0x42000000 - ${fdtcontroladdr}"
+# CONFIG_CMD_BOOTI is not set
+# CONFIG_CMD_SF is not set
+# CONFIG_SPI_FLASH is not set
+CONFIG_LZ4=y
diff --git a/include/configs/milkv-vega.h b/include/configs/milkv-vega.h
new file mode 100644
index 0000000000..b147ffdda7
--- /dev/null
+++ b/include/configs/milkv-vega.h
@@ -0,0 +1,15 @@
+/* SPDX-License-Identifier: GPL-2.0+ */
+/*
+ * Milk-V Vega (Fisilink FSL91030M / Nuclei UX608) board config.
+ *
+ * Almost nothing here — modern u-boot moves configuration to
+ * defconfig. We just declare the SDRAM base; the timer frequency
+ * and everything else comes from the device tree.
+ */
+
+#ifndef __MILKV_VEGA_H
+#define __MILKV_VEGA_H
+
+#define CFG_SYS_SDRAM_BASE	0x41000000
+
+#endif /* __MILKV_VEGA_H */
