+
+config SYS_CPU
+	default "generic"
+
+config SYS_CONFIG_NAME
+	default "milkv-vega"
+
+config TEXT_BASE
+	default 0x41200000
+
+config BOARD_SPECIFIC_OPTIONS # dummy
