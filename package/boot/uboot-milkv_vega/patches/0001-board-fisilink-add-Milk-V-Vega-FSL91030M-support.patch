+	select GENERIC_RISCV
+	imply OF_HAS_PRIOR_STAGE
+	imply HUSH_PARSER
+	imply SIFIVE_SERIAL
+	imply CMD_MTD
+	imply DM_MTD
+	imply MTD
+	imply MTD_SPI_NAND
+	imply SPI
+	imply DM_SPI
+	imply SPI_MEM
+	imply SPI_SIFIVE
+
+endif
