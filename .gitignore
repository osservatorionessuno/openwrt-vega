# Build artifacts (the build.sh script clones OpenWrt here)
/openwrt/

# Local tool checkouts (generated by scripts/flashing/vega/bootstrap.sh or old workflows)
/scripts/flashing/vega/riscv-openocd/
/riscv-openocd/

# Tarballs / blobs that shouldn't be committed
*.tar.xz
*.tar.gz
*.tar.bz2
*.bin
*.ubi
*.ko

# Vendor binary blobs and backup configs
**/config-*.bak
**/*.bak

# Editor scratch
*~
.*.swp
.DS_Store
