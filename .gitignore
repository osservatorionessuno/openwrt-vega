# Build artifacts (the build.sh script clones OpenWrt here)
/openwrt/

# Tarballs / blobs that shouldn't be committed
*.tar.xz
*.tar.gz
*.tar.bz2
*.bin
*.ubi
*.ko

# Vendor binary blobs and backup configs
**/config-*.bak
**/*.bak

# Lab/runtime evidence. Keep this outside the production target image.
/runtime-artifacts/

# Editor scratch
*~
.*.swp
.DS_Store
