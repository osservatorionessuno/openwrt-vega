#!/bin/sh
# SPDX-License-Identifier: GPL-2.0-only
#
# The Vega board currently has no verified bootloader or hardware RNG seed.
# Run OpenWrt's standard jitter RNG once during preinit so procd/ubusd can
# reach the normal init stage; the rc.d urngd service owns the long-running
# supervised daemon later in boot.

milkv_vega_seed_early_urngd() {
	local entropy i pid

	[ -x /sbin/urngd ] || return
	[ -c /dev/random ] || return
	pidof urngd >/dev/null 2>&1 && return

	/sbin/urngd &
	pid="$!"

	for i in 1 2 3 4 5 6 7 8; do
		sleep 1
		entropy="$(cat /proc/sys/kernel/random/entropy_avail 2>/dev/null)"
		[ "${entropy:-0}" -ge 256 ] 2>/dev/null && break
	done

	kill "$pid" 2>/dev/null || true
	wait "$pid" 2>/dev/null || true
}

boot_hook_add preinit_main milkv_vega_seed_early_urngd
